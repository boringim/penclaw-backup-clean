# OpenClaw 增强服务配置
# ========================
# 此文件用于记录环境变量配置，可将以下内容添加到 ~/.bashrc 或 PowerShell 配置文件

# RelayPlane 智能路由代理（省钱 40-60%）
export ANTHROPIC_BASE_URL=http://localhost:3001
export OPENAI_BASE_URL=http://localhost:3001

# ClawSec 安全监控（可选，如需启用见下方）
# export HTTP_PROXY=http://127.0.0.1:8888
# export HTTPS_PROXY=http://127.0.0.1:8888

# 当前配置的模型
# 默认模型已切换为: codex-local/gpt-5.4
# 别名 CODEX08042 指向该模型

# 验证命令:
#   echo $ANTHROPIC_BASE_URL   # 应显示 http://localhost:3001
#   curl http://localhost:3001/v1/models  # 应返回模型列表
#   openclaw models status     # 查看当前模型配置
